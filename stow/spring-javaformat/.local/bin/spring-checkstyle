#!/usr/bin/env bash
# Checkstyle with the Spring conventions from spring-io/spring-javaformat.
#
# Runs com.puppycrawl.tools.checkstyle.Main with the
# spring-javaformat-checkstyle extension on the classpath, so
# `-c io/spring/javaformat/checkstyle/checkstyle.xml` (a classpath
# resource) works exactly like the project's Maven/Gradle wiring.
# Checkstyle is pinned to the version spring-javaformat builds against.
set -euo pipefail

VERSION="${SPRING_JAVAFORMAT_VERSION:-0.0.47}"
CS_VERSION="${SPRING_CHECKSTYLE_VERSION:-9.3}"
DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/spring-javaformat/checkstyle-$CS_VERSION-$VERSION"
CS_JAR="$DATA_DIR/checkstyle-all.jar"
SPRING_JAR="$DATA_DIR/spring-javaformat-checkstyle.jar"
CONFIG_JAR="$DATA_DIR/spring-javaformat-config.jar"

if [[ ! -f "$CS_JAR" || ! -f "$SPRING_JAR" || ! -f "$CONFIG_JAR" ]]; then
  echo "spring-checkstyle: bootstrapping checkstyle $CS_VERSION + spring-javaformat $VERSION" >&2
  mkdir -p "$DATA_DIR"
  curl -fsSL -o "$CS_JAR" \
    "https://github.com/checkstyle/checkstyle/releases/download/checkstyle-$CS_VERSION/checkstyle-$CS_VERSION-all.jar"
  curl -fsSL -o "$SPRING_JAR" \
    "https://repo1.maven.org/maven2/io/spring/javaformat/spring-javaformat-checkstyle/$VERSION/spring-javaformat-checkstyle-$VERSION.jar"
  curl -fsSL -o "$CONFIG_JAR" \
    "https://repo1.maven.org/maven2/io/spring/javaformat/spring-javaformat-config/$VERSION/spring-javaformat-config-$VERSION.jar"
fi

exec java -cp "$CS_JAR:$SPRING_JAR:$CONFIG_JAR" com.puppycrawl.tools.checkstyle.Main "$@"
