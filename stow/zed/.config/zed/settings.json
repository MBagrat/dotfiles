{
  "assistant": {
    "version": "1",
    "default_open_ai_model": "gpt-3.5-turbo",
    "provider": {
      "name": "openai",
      "default_model": "gpt-4o",
      "available_models": ["gpt-4", "gpt-4-turbo-preview", "gpt-4o", "gpt-3.5-turbo"]
    }
  },
  "theme": {
    "mode": "system",
    "dark": "Tokyo Night",
    "light": "Tokyo Night Light"
  },
  "ui_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "ui_font_size": 15,
  "buffer_font_size": 15,
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "relative_line_numbers": true,
  "auto_install_extensions": {
    "toml": true,
    "java": true,
    "kotlin": true,
    "liquid": true,
    "tmux": true,
    "git-firefly": true,
    "dockerfile": true,
    "docker-compose": true,
    "tokyo-night": true,
    "intellij-newui-theme": true
  }
}
